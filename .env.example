# LLM providers
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AWS_BEDROCK_REGION=us-east-1

# Default provider (mock | groq | openai | anthropic | bedrock)
CODEINTEL_PROVIDER=mock
CODEINTEL_MODEL=

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
GITHUB_ACCESS_TOKEN=

# Database / cache
DATABASE_URL=postgresql+psycopg://codeintel:codeintel@localhost:5432/codeintel
REDIS_URL=redis://localhost:6379/0

# Sandbox
CODEINTEL_SANDBOX=local  # local (dev only) | docker
CODEINTEL_SANDBOX_PY_IMAGE=ghcr.io/codeintel/sandbox-py:3.12
CODEINTEL_SANDBOX_NODE_IMAGE=ghcr.io/codeintel/sandbox-node:20

# Auth (Clerk)
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_RUNS=
STRIPE_PRICE_SANDBOX_SECONDS=
STRIPE_PRICE_SEAT=

# Telemetry
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
